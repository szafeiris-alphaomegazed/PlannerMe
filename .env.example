# Copy this file to .env and fill in your own PlannerUs/OpenProject values.

PLANNERUS_BASE_URL=https://app.plannerus.com
PLANNERUS_AUTH=basic
PLANNERUS_API_KEY=replace_with_your_plannerus_api_key

# Optional. Useful for MCP clients that start outside this directory.
# PLANNERME_ENV_FILE=/absolute/path/to/your/.env

# Tasks used for time logging are detected by this subject prefix.
PLANNERUS_LOG_TASK_PREFIX=LOG_

# Optional. Leave blank to let PlannerUs use its default activity, or set an id.
PLANNERUS_DEFAULT_ACTIVITY_ID=

# Optional project aliases. Use alias:project_id_or_identifier, separated by commas.
# Bare project identifiers are also accepted and act as their own alias.
PLANNERUS_PROJECTS=clienta:123,clientb:client-b-identifier,whistleblowing-platform

# Defaults for autolog.
PLANNERUS_DAILY_HOURS=8
PLANNERUS_WEEKLY_HOURS=40
